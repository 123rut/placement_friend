{
  "name": "careerpilot-ai",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @piaa/web run dev",
    "build:web": "npm --workspace @piaa/web run build",
    "lint:web": "npm --workspace @piaa/web run lint",
    "typecheck:web": "npm --workspace @piaa/web run typecheck",
    "dev:api": "npm --workspace api run start:dev",
    "build:api": "npm --workspace api run build",
    "start:api": "npm --workspace api run start:prod",
    "dev:worker": "npm --workspace @piaa/worker run dev",
    "build:worker": "npm --workspace @piaa/worker run build",
    "typecheck:worker": "npm --workspace @piaa/worker run typecheck",
    "build": "npm run build:api && npm run build:worker && npm run build:web",
    "typecheck": "npm run typecheck:worker && npm run typecheck:web",
    "validate:companies": "node scripts/validate-company-catalog.mjs",
    "validate:companies:metadata": "node scripts/validate-company-catalog.mjs --metadata-only",
    "db:init": "node --experimental-strip-types infra/init-db.ts"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
